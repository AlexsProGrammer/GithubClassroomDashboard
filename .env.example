# Firebase project configuration from your Firebase Console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# GitHub Classroom repository owner.
# Enter the GitHub organization or user that owns the assignment repositories.
# Example: my-university-classroom-org
VITE_GITHUB_CLASSROOM_OWNER=

# GitHub Classroom repository name prefix (optional but recommended).
# Use the shared beginning of all assignment repos to filter unrelated repos.
# Example: Quest-EiP
VITE_GITHUB_CLASSROOM_REPO_PREFIX=

# Optional manual verification target used by older Phase 3 checks.
VITE_GITHUB_VERIFY_OWNER=
VITE_GITHUB_VERIFY_REPO=

# Musterloesung (solutions) repository (optional).
# Enter the owner and repo where solution folders are stored.
# The app checks for a folder that matches the assignment repository name.
# Example link generated when present:
# https://github.dev/<VITE_GITHUB_SOLUTIONS_OWNER>/<VITE_GITHUB_SOLUTIONS_REPO>/tree/main/<assignment-repo-name>
VITE_GITHUB_SOLUTIONS_OWNER=
VITE_GITHUB_SOLUTIONS_REPO=